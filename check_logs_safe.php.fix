<?php
header('Content-Type: text/plain');
$logFile = __DIR__.'/../../../loyalty-backend/storage/logs/laravel.log';
if (file_exists($logFile)) {
    echo "LOG FILE FOUND\n";
    $f = fopen($logFile, 'r');
    fseek($f, -2000, SEEK_END);
    $output = fread($f, 2000);
    fclose($f);
    echo "LAST ~2000 BYTES:\n";
    echo $output;
} else {
    echo "LOG FILE NOT FOUND\n";
}
